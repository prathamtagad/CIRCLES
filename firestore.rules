rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the update is ONLY changing the followers count
    function isFollowerCountUpdate() {
      // Use get() for null safety in case field doesn't exist yet
      let prevCount = resource.data.get('followersCount', 0);
      let newCount = request.resource.data.followersCount;
      
      // Ensure only followersCount is being changed
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']) &&
             // Ensure it's a number
             newCount is number &&
             // Ensure it's exactly +1 or -1
             (newCount == prevCount + 1 || newCount == prevCount - 1);
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Owner can edit their own profile
      allow create: if isOwner(userId);
      
      // Update logic:
      // 1. Owner can update everything
      // 2. Others can ONLY update 'followersCount' if logic is valid
      allow update: if isOwner(userId) || (isAuthenticated() && isFollowerCountUpdate());
      
      // Subcollection: Followers
      match /followers/{followerId} {
      	allow read: if isAuthenticated();
        // The FOLLOWER (request.auth.uid) adds themselves as a document to the user's subcollection
        // So the ID of the document ({followerId}) must match the requester
        allow create: if isOwner(followerId);
        allow delete: if isOwner(followerId); 
      }
      
      // Subcollection: Following
      match /following/{followingId} {
      	allow read: if isAuthenticated();
        // The USER (owner of parent doc) adds who they are following
        allow create, delete: if isOwner(userId);
      }
    }

    // CIRCLES COLLECTION
    match /circles/{circleId} {
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      allow read: if isAuthenticated() && (
      	resource.data.ownerId == request.auth.uid || 
        request.auth.token.email in resource.data.members ||
        resource.data.ownerId != null
      );
    }

    // POSTS COLLECTION
    match /posts/{postId} {
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow read: if isAuthenticated(); 
    }
  }
}
